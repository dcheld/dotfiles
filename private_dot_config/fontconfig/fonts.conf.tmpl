<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>

  <!-- Sans padrão -->
  <alias>
    <family>sans-serif</family>
    <prefer>
      <family>{{ .fontFamily }}</family>
    </prefer>
  </alias>

  <!-- Serif padrão -->
  <alias>
    <family>serif</family>
    <prefer>
      <family>{{ .fontFamily }}</family>
    </prefer>
  </alias>

  <!-- Monospace padrão -->
  <alias>
    <family>monospace</family>
    <prefer>
      <family>{{ .fontFamily }}</family>
    </prefer>
  </alias>

</fontconfig>
